{
  "name": "cmaf-lite",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/main.mjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.mts",
  "exports": {
    ".": {
      "import": "./dist/main.mjs",
      "types": "./dist/main.d.mts"
    },
    "./dash": {
      "import": "./dist/dash.mjs",
      "types": "./dist/dash.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --minify",
    "dev": "tsdown --watch",
    "docs": "api-extractor run --local --config api-generator/config.json && api-documenter markdown -i api-generator/__generated__ -o api-generator/__generated__/markdown",
    "check": "biome check",
    "format": "biome check --write --unsafe .",
    "tsc": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "^7.30.0",
    "@microsoft/api-extractor": "^7.58.2",
    "@relative-ci/rollup-plugin": "^5.3.1",
    "@types/node": "^25.5.2",
    "happy-dom": "^20.8.9",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@matvp91/eventemitter3": "^5.0.1",
    "@svta/cml-dash": "^1.0.5",
    "@svta/cml-iso-8601": "^1.0.1",
    "@svta/cml-iso-bmff": "^1.0.1",
    "@svta/cml-utils": "^1.4.0",
    "fast-xml-parser": "^5.4.1"
  }
}
